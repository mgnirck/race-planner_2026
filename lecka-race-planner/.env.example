# Lecka Race Planner — environment variables
# Copy this file to .env.local for local development.
# Set all variables in the Vercel dashboard before deploying.
# See public/shopify-embed-instructions.md for full setup guide.

# ── Required: Email (Resend) ───────────────────────────────────────────────────
# Obtain from https://resend.com/api-keys
# The from address (info@getlecka.com) must be verified in Resend → Domains.
RESEND_API_KEY=re_...

# ── Required: Shopify Admin API ────────────────────────────────────────────────
# Create a private app in Shopify Admin → Settings → Apps → Develop apps.
# Required scopes: read_customers, write_customers
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_STORE_URL=getlecka.myshopify.com

# ── Required: Admin dashboard password ────────────────────────────────────────
# Protects the /admin stats page. Compared client-side — use for non-sensitive
# aggregate stats only. Choose a strong random string.
VITE_ADMIN_PASSWORD=change-me-before-deploying

# ── Required: Vercel Postgres ──────────────────────────────────────────────────
# Automatically injected when you link a Vercel Postgres database in the Vercel
# dashboard (Storage → Create Database → Postgres). Copy the values shown under
# "Quickstart → .env.local" into your local .env.local for local development.
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_USER=...
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=...

# ── Required: Magic-link auth ──────────────────────────────────────────────────
# The app uses passwordless email login. RESEND_API_KEY is already listed above.
# After deploying, call POST /api/migrate to create the database tables once.
# No additional variables are needed — userId (UUID) is used as the bearer token.

# ── Optional: Deployment URL ───────────────────────────────────────────────────
# Used by api/send-plan.js to call /api/products internally (SSR product fetch).
# Vercel sets this automatically. Only needed for local dev if your port differs.
# VERCEL_URL=localhost:3000
