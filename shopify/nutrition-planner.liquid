{% comment %}
  Lecka Ernæringsplanlægger — nutrition-planner.liquid
  ====================================================
  Gem denne fil som: Sections > nutrition-planner.liquid
  i Shopify Theme Editor (Online Store → Themes → Edit code).

  Tilføj sektionen til en side via Customize → Add section → Ernæringsplanlægger.
{% endcomment %}

{%- assign planner_url = section.settings.planner_url | strip_newlines | strip -%}

<div
  class="lecka-planner-section"
  id="lecka-planner-{{ section.id }}"
  style="width:100%; overflow:hidden; {{ section.settings.padding_top | prepend: 'padding-top:' | append: 'px;' }} {{ section.settings.padding_bottom | prepend: 'padding-bottom:' | append: 'px;' }}"
>
  <script src="{{ planner_url }}/embed.js" defer></script>

  <iframe
    data-lecka
    id="lecka-iframe-{{ section.id }}"
    src="{{ planner_url }}/?region=dk&lang=da&utm_source=shopify_embed"
    width="100%"
    height="700"
    frameborder="0"
    scrolling="no"
    title="Lecka Løbeplan Ernæringsplanlægger"
    loading="lazy"
    style="display:block; border:none; width:100%; min-height:600px;"
    allow="clipboard-write"
  ></iframe>
</div>

{% schema %}
{
  "name": "Ernæringsplanlægger",
  "tag": "section",
  "class": "section-nutrition-planner",
  "settings": [
    {
      "type": "text",
      "id": "planner_url",
      "label": "Planner URL",
      "default": "https://plan.getlecka.com",
      "info": "URL til den deployede planner-app. Ingen afsluttende skråstreg."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Afstand øverst",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Afstand nederst",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Ernæringsplanlægger"
    }
  ]
}
{% endschema %}
